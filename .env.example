# =============================================================================
# FlowRAG-Agent Environment Configuration
# Copy to .env and adjust values for your environment.
# =============================================================================

# --- Application ---
APP_NAME=FlowRAG-Agent
DEBUG=false

# --- Paths ---
DATA_DIR=data
UPLOADS_DIR=data/uploads
CHROMA_PERSIST_DIR=data/chroma
REGISTRY_PATH=data/registry.db

# --- ChromaDB ---
CHROMA_COLLECTION_NAME=flowrag_docs

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
PAGE_BREAK_STRATEGY=intra_page

# --- Retrieval ---
DEFAULT_TOP_K=6
SCORE_THRESHOLD=0.42
MAX_CONTEXT_CHUNKS=8
MAX_CONTEXT_TOKENS=4000

# --- LLM Provider: ollama | openai | openai_compatible ---
LLM_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# OpenAI / OpenAI-compatible API
# Prefer LLM_API_KEY so a global OPENAI_API_KEY env var does not override this project.
LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# --- Embeddings ---
# Provider: huggingface | openai
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
# HuggingFace mirror (leave empty to use huggingface.co)
HF_ENDPOINT=https://hf-mirror.com

# OpenAI embeddings (when EMBEDDING_PROVIDER=openai)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
